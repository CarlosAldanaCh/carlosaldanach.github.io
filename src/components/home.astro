---
import LetterGlitch from "../React/LetterGlitch.tsx";
import LogoWall from "../components/logoWall.astro";
import SkillsList from "../React/SkillsList.tsx";
---

<section class="text-[var(--white)] mt-12 md:mt-0" id="home">
  <div class="max-w-5xl mx-auto space-y-10 md:py-28 pb-14">
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] gap-10 lg:gap-12 items-center">
      <div class="text-left space-y-5">
        <p class="text-xl md:text-2xl text-[var(--white)] font-medium tracking-[0.01em]">
          Hi, I'm <span class="shiny-sec">Carlos Aldana Chico</span>
        </p>

        <div class="space-y-4">
          <h1 class="text-[var(--white)] text-5xl md:text-6xl font-medium text-pretty leading-[0.95]">
            Data Scientist <br />
            ML & Analytics | Remote
          </h1>

          <div class="max-w-xl space-y-3">
            <p class="text-lg md:text-xl text-[var(--white-icon)] leading-snug">
              I build end-to-end ML projects.
            </p>

            <p class="text-sm md:text-base leading-relaxed text-[var(--white-icon)]">
              <span class="shiny-sec font-semibold">
                data cleaning → EDA → feature engineering → modeling → evaluation → business-ready insights.
              </span>
            </p>
          </div>
        </div>

        <div class="space-y-2 pt-2">
          <p class="text-[var(--white-icon)] text-sm md:text-base max-w-3xl">
            Bootcamp-trained Data Scientist (TripleTen) with hands-on projects in tabular regression and
            Computer Vision (ResNet50 transfer learning). Strong Python stack (pandas, NumPy, scikit-learn)
            and growing SQL (PostgreSQL).
          </p>
          <p class="text-[var(--white-icon)] text-sm md:text-base max-w-3xl">
            <span class="text-[var(--sec)]">ES:</span> Busco oportunidades 100% remotas como Junior Data Scientist / ML Analyst / Data Analyst (Modeling).
          </p>
        </div>

        <div class="flex flex-wrap gap-3 pt-3 md:pt-5">
          <a
            href="#projects"
            class="px-5 py-3 rounded-xl border border-[#ffffff14] bg-[#14141466] backdrop-blur-sm hover:bg-[#1414149c] transition
            shadow-[0_0_0_1px_rgba(164,118,255,0.18),0_0_24px_rgba(164,118,255,0.14)]"
          >
            <span class="shiny-sec font-semibold">View Projects</span>
          </a>

          <a
            href="/Carlos_Aldana_Resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="px-5 py-3 rounded-xl border border-[var(--white-icon-tr)] text-[var(--white)] hover:bg-[var(--white-icon-tr)] transition"
          >
            Download Resume
          </a>

          <a
            href="#contact"
            class="px-5 py-3 rounded-xl border border-[var(--white-icon-tr)] text-[var(--white)] hover:bg-[var(--white-icon-tr)] transition"
          >
            Contact
          </a>
        </div>

        <div class="flex justify-start gap-2 pt-2">
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://github.com/CarlosAldanaCh"
            aria-label="GitHub"
            class="text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-3 rounded-xl bg-[#1414149c] hover:bg-[var(--white-icon-tr)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8">
              <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"></path>
            </svg>
          </a>

          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.linkedin.com/in/carlosaldanach/"
            aria-label="LinkedIn"
            class="text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-3 rounded-xl bg-[#1414149c] hover:bg-[var(--white-icon-tr)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8">
              <path d="M18.3362 18.339H15.6707V14.1622C15.6707 13.1662 15.6505 11.8845 14.2817 11.8845C12.892 11.8845 12.6797 12.9683 12.6797 14.0887V18.339H10.0142V9.75H12.5747V10.9207H12.6092C12.967 10.2457 13.837 9.53325 15.1367 9.53325C17.8375 9.53325 18.337 11.3108 18.337 13.6245V18.339H18.3362ZM7.00373 8.57475C6.14573 8.57475 5.45648 7.88025 5.45648 7.026C5.45648 6.1725 6.14648 5.47875 7.00373 5.47875C7.85873 5.47875 8.55173 6.1725 8.55173 7.026C8.55173 7.88025 7.85798 8.57475 7.00373 8.57475ZM8.34023 18.339H5.66723V9.75H8.34023V18.339ZM19.6697 3H4.32923C3.59498 3 3.00098 3.5805 3.00098 4.29675V19.7033C3.00098 20.4202 3.59498 21 4.32923 21H19.6675C20.401 21 21.001 20.4202 21.001 19.7033V4.29675C21.001 3.5805 20.401 3 19.6675 3H19.6697Z"></path>
            </svg>
          </a>

          <a
            href="mailto:carlosaldanaoficial@gmail.com?subject=Opportunity%20-%20Data%20Science%20Role"
            aria-label="Email"
            class="text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-3 rounded-xl bg-[#1414149c] hover:bg-[var(--white-icon-tr)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="2.1em" height="2.1em" viewBox="0 0 24 24">
              <path fill="currentColor" d="m18.73 5.41l-1.28 1L12 10.46L6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <div class="portrait-stage group relative isolate w-full max-w-[24rem] sm:max-w-[26rem] lg:max-w-[28rem] h-[25rem] sm:h-[30rem] lg:h-[34rem] overflow-hidden rounded-[2rem] border border-[#ffffff12] bg-[linear-gradient(180deg,rgba(255,255,255,0.03),rgba(255,255,255,0.01))] shadow-[0_0_0_1px_rgba(164,118,255,0.18),0_25px_80px_rgba(0,0,0,0.36)] transition-[transform,box-shadow,border-color] duration-500 ease-out hover:-translate-y-1 hover:border-[rgba(164,118,255,0.45)] hover:shadow-[0_0_0_1px_rgba(164,118,255,0.28),0_0_38px_rgba(164,118,255,0.18),0_25px_80px_rgba(0,0,0,0.42)]">
          <div class="absolute inset-x-10 top-6 h-28 rounded-full bg-[radial-gradient(circle,rgba(164,118,255,0.38),transparent_70%)] blur-2xl transition-all duration-500 group-hover:scale-110 group-hover:opacity-100"></div>
          <div class="absolute inset-x-6 bottom-0 h-[74%] rounded-t-[2rem] bg-[linear-gradient(180deg,rgba(164,118,255,0.22),rgba(36,26,56,0.06)_32%,rgba(16,16,16,0.72)_100%)] transition-all duration-500 group-hover:from-[rgba(164,118,255,0.3)]"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.04),transparent_38%)]"></div>
          <div class="absolute inset-x-6 inset-y-6 rounded-[1.65rem] border border-[rgba(164,118,255,0.24)] transition-colors duration-500 group-hover:border-[rgba(190,150,255,0.42)]"></div>
          <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-[var(--background)] via-[rgba(16,16,16,0.82)] to-transparent z-20"></div>

          <img
            src="/images/carlos-aldana-portrait.png"
            alt="Portrait of Carlos Aldana Chico"
            class="portrait-image absolute left-1/2 top-5 z-10 h-[142%] sm:h-[145%] lg:h-[148%] w-auto max-w-none -translate-x-1/2 object-contain transition-[transform,filter] duration-500 ease-out group-hover:scale-[1.025]"
            loading="eager"
            decoding="async"
          />

          <div class="portrait-chip absolute left-5 top-5 z-30 rounded-full border border-[rgba(164,118,255,0.32)] bg-[rgba(16,16,16,0.72)] px-3 py-1 text-xs uppercase tracking-[0.24em] text-[var(--white)] backdrop-blur-md transition-[border-color,box-shadow,transform] duration-500 ease-out group-hover:-translate-y-0.5 group-hover:border-[rgba(201,170,255,0.52)] group-hover:shadow-[0_0_18px_rgba(164,118,255,0.24)]">
            Carlos Aldana
          </div>
        </div>
      </div>
    </div>

    <LogoWall />

    <div class="flex flex-col lg:flex-row items-center gap-8">
      <SkillsList client:load />
      <div class="flex justify-center md:w-full md:h-[292px] size-[290px] pt-3 md:pt-9 md:ml-16">
        <LetterGlitch
          client:load
          glitchColors={["#5e4491", "#A476FF", "#241a38"]}
          glitchSpeed={33}
          centerVignette={false}
          outerVignette={true}
          smooth={true}
        />
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Glow sólido para keywords (legible SIEMPRE) */
  .glow-sec {
    text-shadow:
      0 0 14px rgba(164, 118, 255, 0.22),
      0 0 2px rgba(242, 236, 255, 0.18);
  }

  /* Mantén el "shine" pero úsalo solo en una parte corta (insights) */
  .shiny-sec {
    color: #a476ff;
  }

  @supports ((-webkit-background-clip: text) or (background-clip: text)) {
    .shiny-sec {
      background: linear-gradient(135deg, #a476ff 14%, #f4eeff 50%, #a476ff 86%);
      background-size: 240% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;

      text-shadow:
        0 0 14px rgba(164, 118, 255, 0.24),
        0 0 2px rgba(242, 236, 255, 0.18);

      filter: saturate(1.28) brightness(1.14);
      animation: shine 5.6s linear infinite;
    }
  }

  @keyframes shine {
    0% { background-position: 110% 50%; }
    50% { background-position: 0% 50%; }
    100% { background-position: 110% 50%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shiny-sec { animation: none; }
  }

  .portrait-stage::after {
    content: "";
    position: absolute;
    inset: auto 14% 5% 14%;
    height: 18%;
    border-radius: 9999px;
    background: radial-gradient(circle, rgba(164, 118, 255, 0.42), transparent 72%);
    filter: blur(34px);
    z-index: 1;
    transition:
      transform 500ms ease-out,
      opacity 500ms ease-out,
      filter 500ms ease-out;
  }

  .portrait-stage:hover::after {
    transform: scale(1.08);
    opacity: 1;
    filter: blur(40px);
  }

  .portrait-stage::before {
    content: "";
    position: absolute;
    inset: -28% -10%;
    background: conic-gradient(
      from 180deg,
      rgba(125, 60, 255, 0) 0deg,
      rgba(125, 60, 255, 0.18) 58deg,
      rgba(248, 240, 255, 0.16) 104deg,
      rgba(166, 92, 255, 0.22) 182deg,
      rgba(125, 60, 255, 0) 250deg,
      rgba(125, 60, 255, 0) 360deg
    );
    opacity: 0.6;
    filter: blur(28px);
    transform: translate3d(0, 0, 0);
    animation: portraitFlow 7s linear infinite;
    pointer-events: none;
    z-index: 0;
  }

  .portrait-image {
    filter:
      drop-shadow(0 0 24px rgba(164, 118, 255, 0.28))
      drop-shadow(0 0 48px rgba(125, 60, 255, 0.12))
      drop-shadow(0 12px 40px rgba(0, 0, 0, 0.42));
  }

  .group:hover .portrait-image {
    filter:
      drop-shadow(0 0 28px rgba(164, 118, 255, 0.34))
      drop-shadow(0 0 60px rgba(125, 60, 255, 0.18))
      drop-shadow(0 18px 52px rgba(0, 0, 0, 0.46));
  }

  .portrait-chip {
    background-image: linear-gradient(135deg, rgba(125, 60, 255, 0.1), rgba(248, 240, 255, 0.03), rgba(166, 92, 255, 0.12));
  }

  @keyframes portraitFlow {
    0% {
      transform: rotate(0deg) scale(1);
      opacity: 0.38;
    }
    50% {
      transform: rotate(180deg) scale(1.06);
      opacity: 0.7;
    }
    100% {
      transform: rotate(360deg) scale(1);
      opacity: 0.38;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .portrait-stage::before,
    .portrait-stage::after,
    .portrait-image,
    .portrait-chip,
    .portrait-stage {
      animation: none;
      transition: none;
      transform: none;
    }
  }
</style>
